
import pandas as pd
import dash
from dash import Dash, html, dcc
from dash.dependencies import Input, Output, State
import plotly.express as px

app = Dash(__name__)
app.config.suppress_callback_exceptions = True

# Load data
airline_data = pd.read_csv(
    'https://cf-courses-data.s3.us.cloud-object-storage.appdomain.cloud/IBMDeveloperSkillsNetwork-DV0101EN-SkillsNetwork/Data%20Files/airline_data.csv',
    encoding="ISO-8859-1"
)

year_list = list(range(2005, 2021))


def compute_data_choice_1(df):
    bar_data = df.groupby(['Month','CancellationCode'])['Flights'].sum().reset_index()
    line_data = df.groupby(['Month','Reporting_Airline'])['AirTime'].mean().reset_index()
    div_data = df[df['DivAirportLandings'] != 0.0]
    map_data = df.groupby(['OriginState'])['Flights'].sum().reset_index()
    tree_data = df.groupby(['DestState','Reporting_Airline'])['Flights'].sum().reset_index()
    return bar_data, line_data, div_data, map_data, tree_data


def compute_data_choice_2(df):
    avg_car = df.groupby(['Month','Reporting_Airline'])['CarrierDelay'].mean().reset_index()
    avg_weather = df.groupby(['Month','Reporting_Airline'])['WeatherDelay'].mean().reset_index()
    avg_NAS = df.groupby(['Month','Reporting_Airline'])['NASDelay'].mean().reset_index()
    avg_sec = df.groupby(['Month','Reporting_Airline'])['SecurityDelay'].mean().reset_index()
    avg_late = df.groupby(['Month','Reporting_Airline'])['LateAircraftDelay'].mean().reset_index()
    return avg_car, avg_weather, avg_NAS, avg_sec, avg_late


# Layout
app.layout = html.Div([
    html.H1("US Domestic Airline Flights Dashboard", style={'textAlign':'center'}),

    dcc.Dropdown(
        id='input-type',
        options=[
            {'label':'Performance Report','value':'OPT1'},
            {'label':'Delay Report','value':'OPT2'}
        ],
        placeholder="Select Report Type"
    ),

    dcc.Dropdown(
        id='input-year',
        options=[{'label':i,'value':i} for i in year_list],
        placeholder="Select Year"
    ),

    html.Div(id='output')
])


@app.callback(
    Output('output','children'),
    [Input('input-type','value'),
     Input('input-year','value')]
)
def update_graph(chart, year):

    if not chart or not year:
        return "Please select both options"

    df = airline_data[airline_data['Year'] == int(year)]

    if chart == 'OPT1':
        bar_data, line_data, div_data, map_data, tree_data = compute_data_choice_1(df)

        return [
            dcc.Graph(figure=px.bar(bar_data, x='Month', y='Flights', color='CancellationCode')),
            dcc.Graph(figure=px.line(line_data, x='Month', y='AirTime', color='Reporting_Airline')),
            dcc.Graph(figure=px.pie(div_data, values='Flights', names='Reporting_Airline')),
            dcc.Graph(figure=px.choropleth(map_data, locations='OriginState', color='Flights', locationmode='USA-states')),
            dcc.Graph(figure=px.treemap(tree_data, path=['DestState','Reporting_Airline'], values='Flights'))
        ]

    else:
        avg_car, avg_weather, avg_NAS, avg_sec, avg_late = compute_data_choice_2(df)

        return [
            dcc.Graph(figure=px.line(avg_car, x='Month', y='CarrierDelay', color='Reporting_Airline')),
            dcc.Graph(figure=px.line(avg_weather, x='Month', y='WeatherDelay', color='Reporting_Airline')),
            dcc.Graph(figure=px.line(avg_NAS, x='Month', y='NASDelay', color='Reporting_Airline')),
            dcc.Graph(figure=px.line(avg_sec, x='Month', y='SecurityDelay', color='Reporting_Airline')),
            dcc.Graph(figure=px.line(avg_late, x='Month', y='LateAircraftDelay', color='Reporting_Airline'))
        ]


if __name__ == '__main__':
    app.run(debug=True)  
